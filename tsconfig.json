{
  "compilerOptions": {
    "target": "ES6",
    "allowJs": true,
    "module": "commonjs",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "paths": {
      "*": [
        "node_modules/*"
      ],
      "@/*": [
        "./*"
      ],
      "@renderer/*": [
        "./src/renderer/*"
      ],
      "@api/*": [
        "./src/renderer/services/api/*"
      ],
      "@assets/*": [
        "./src/renderer/assets/*"
      ]
    },
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*",
    "src/renderer/@types/*",
    "src/electron/@types/*"
  ]
}